  m_Script: {fileID: 11500000, guid: 4ea1aaa1e9e77a04e9d9634cb02c41cd, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  menuPanel: {fileID: 1719645975}
  levelsPanel: {fileID: 937052311}
  settingsPanel: {fileID: 1974486188}
  scoreboardPanel: {fileID: 1431924145}
  creditsPanel: {fileID: 799926256}
  audioSource: {fileID: 59037122}
  storyLines:
  - 'My name is Fern.\n\n[Press X key to continue]'
  - I am a part of a cult...
  - Or at least, I used to be...
  - 'Until I got exiled. '
  - I was... I do not even know how to say it... resilient? Ignorant? Irrational?
  - Defiant... ah, defiant! Yes, I was defiant to the cult.
  - I did not want to be a part of their horrific practice, so I escaped.
  - I ran away... the only belonging I carried with me was a sword named Brad.
  - I realized I did not want others to suffer because of the cult's practice.
  - With the help of Brad, I am determined to take down the Drintell Empire once
    and for all.
  storyController: {fileID: 2050815090}
